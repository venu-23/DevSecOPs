pipeline {
  agent { label 'buildnode' }

  environment {
    AWS_ACCOUNT_ID = "942909610557"
    AWS_REGION = "ap-south-1"
    ECR_REPO = "springboot-app"
    IMAGE_TAG = "${BUILD_NUMBER}"   // ✅ changed from latest
    IMAGE_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:${IMAGE_TAG}"
    JAVA_HOME = "/usr/lib/jvm/java-21-openjdk-amd64"
    PATH = "${JAVA_HOME}/bin:${env.PATH}"
  }

  stages {

    stage('Checkout') {
      steps {
        git branch: 'main',
            credentialsId: 'venu-23',
            url: 'https://github.com/venu-23/DevSecOPs.git'
      }
    }

    // ✅ merged Build + Code Coverage (removed duplicate build)
    stage('Build & Code Coverage') {
      steps {
        echo "Building and running tests..."
        dir('springboot-build-pipeline') {
          sh """
            java -version
            mvn clean verify
          """
        }
      }
    }

    stage('Stage III: SCA') {
      steps {
        echo "Running SCA..."
        withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY')]) {
          dir('springboot-build-pipeline') {
            sh """
              mvn org.owasp:dependency-check-maven:check \
              -DnvdApiKey=\$NVD_API_KEY \
              -DnvdApiDelay=3000 \
              -DnvdMaxRetryCount=10
            """
          }
        }
      }
    }

    stage('Stage IV: SAST') {
      steps {
        echo "Running SonarQube analysis..."
        withSonarQubeEnv('mysonarqube') {
          dir('springboot-build-pipeline') {
            sh """
              mvn sonar:sonar \
              -Dsonar.projectName=wezvatech \
              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
              -Dsonar.dependencyCheck.jsonReportPath=target/dependency-check-report.json \
              -Dsonar.dependencyCheck.htmlReportPath=target/dependency-check-report.html
            """
          }
        }
      }
    }

    stage('Stage V: QualityGates') {
      steps {
        echo "Checking Quality Gates..."
        script {
          timeout(time: 2, unit: 'MINUTES') {
            def qg = waitForQualityGate()
            if (qg.status != 'OK') {
              error "Pipeline aborted due to quality gate failure: ${qg.status}"
            }
          }
        }
      }
    }

    stage('Build & Push to ECR') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-creds'
        ]]) {
          dir('springboot-build-pipeline') {
            sh """
              echo "Login to ECR"
              aws ecr get-login-password --region ${AWS_REGION} | docker login \
              --username AWS \
              --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

              echo "Build Docker image"
              docker build -t ${ECR_REPO}:${IMAGE_TAG} .

              echo "Tag image"
              docker tag ${ECR_REPO}:${IMAGE_TAG} ${IMAGE_URI}

              echo "Push image"
              docker push ${IMAGE_URI}
            """
          }
        }
      }
    }

    // ✅ FIXED (was wrong image)
    stage('Stage VII: Scan Image') {
      steps {
        echo "Scanning Image..."
        sh """
          trivy image --scanners vuln --severity HIGH,CRITICAL ${IMAGE_URI} > trivyresults.txt
        """
      }
    }

    // ✅ FIXED (was wrong image)
    stage('Stage VIII: Smoke Test') {
      steps {
        echo "Running Smoke Test..."
        sh """
          docker run -d --name smokerun -p 8080:8080 ${IMAGE_URI}
          sleep 60
          curl -f http://localhost:8080 || exit 1
          docker rm -f smokerun
        """
      }
    }
  }

  // ✅ ADDED (important)
  post {
    success {
      echo "Pipeline Success"
      archiveArtifacts artifacts: 'springboot-build-pipeline/target/*.jar', fingerprint: true
      archiveArtifacts artifacts: 'trivyresults.txt', fingerprint: true
    }
    failure {
      echo "Pipeline Failed"
    }
    always {
      cleanWs()
    }
  }
}
